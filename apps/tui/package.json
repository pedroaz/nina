{
  "name": "nina-tui",
  "version": "0.1.3",
  "description": "Nina TUI (OpenTUI)",
  "type": "module",
  "scripts": {
    "dev": "bun run src/main.ts",
    "build": "bun build src/main.ts --outdir dist",
    "build:linux-x64": "bun build src/main.ts --compile --target=bun-linux-x64 --outfile dist/nina-tui-linux-x64",
    "build:macos-x64": "bun build src/main.ts --compile --target=bun-darwin-x64 --outfile dist/nina-tui-macos-x64",
    "build:macos-arm64": "bun build src/main.ts --compile --target=bun-darwin-arm64 --outfile dist/nina-tui-macos-arm64",
    "build:windows-x64": "bun build src/main.ts --compile --target=bun-windows-x64 --outfile dist/nina-tui-windows-x64.exe",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  }
}
